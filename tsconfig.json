{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": true
  },
  "include": [
    "tools/pax-ripper/src/**/*",
    "tools/preset-exporter/src/**/*",
    "tools/preset-exporter/tests/**/*",
    "tools/preset-exporter/scripts/**/*"
  ]
}